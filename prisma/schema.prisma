
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  moduleFormat = "cjs"
  output       = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tweets        Tweet[]
  likes         Like[]
  followers     Follow[]       @relation("followers")
  following     Follow[]       @relation("following")
  refreshTokens RefreshToken[]
  bookmarks     Bookmark[]
  notifications Notification[] @relation("Notification_user")
  actedNotifications Notification[] @relation("NotificationActor")
}

model Tweet {
  id        String    @id @default(uuid())
  content   String?
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  parentId String?
  parent   Tweet?  @relation("Reply", fields: [parentId], references: [id])
  replies  Tweet[] @relation("Reply")

  retweetOfId String?
  retweetOf   Tweet?  @relation("Retweet", fields: [retweetOfId], references: [id])
  retweets    Tweet[] @relation("Retweet")

  likes Like[]

  bookmarks Bookmark[]

  @@index([authorId])
  @@index([createdAt])
}

model Follow {
  followerId  String
  followingId String

  follower  User @relation("following", fields: [followerId], references: [id])
  following User @relation("followers", fields: [followingId], references: [id])

  @@id([followerId, followingId])
  @@index([followingId])
}

model Like {
  userId  String
  tweetId String

  user  User  @relation(fields: [userId], references: [id])
  tweet Tweet @relation(fields: [tweetId], references: [id])

  @@id([userId, tweetId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)

  @@index([userId])
}

model Bookmark {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  tweet     Tweet    @relation(fields: [tweetId], references: [id])
  tweetId   String
  createdAt DateTime @default(now())

  @@unique([userId, tweetId]) 
}


model Notification {
  id          String   @id @default(uuid())
  user        User     @relation("Notification_user", fields: [userId], references: [id])
  userId      String
  actorId     String
  actor       User     @relation("NotificationActor", fields: [actorId], references: [id])
  action      NotificationAction
  targetType  NotificationTarget
  targetId    String?
  textPreview String?
  url         String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
}

enum NotificationAction {
  LIKED
  REPLIED
  RETWEETED
  FOLLOWED
  MENTIONED
}

enum NotificationTarget {
  TWEET
  USER
}